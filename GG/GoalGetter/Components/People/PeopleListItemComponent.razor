@inject IDialogService DialogService
@inject IDeletePersonUseCase deletePersonUseCase
@inject ISnackbar Snackbar

<MudCard Class="person-card d-flex flex-column" Style="height: 100%;" Elevation="2" @onclick="@(() => OpenPersonCard(maxWidth))">
	<MudCardHeader>
		<CardHeaderAvatar>
			@if (person.AvatarPath != null)
			{
				<MudAvatar Image="@person.AvatarPath" />
			}
			else
			{
				<MudAvatar Color="@person.AvatarColor">@person.Firstname.First()@person.Lastname.First()</MudAvatar>
			}
		</CardHeaderAvatar>
		<CardHeaderContent>
			<MudText Typo="Typo.h6" Class="text-truncate">@person.Firstname @person.Lastname</MudText>
		</CardHeaderContent>
		<CardHeaderActions>
			<div @onclick:stopPropagation="true">
				<MudTooltip Text="Remove">
					<MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="delete" OnClick="@(() => DeletePeron(person, person.Firstname, person.Lastname))" />
				</MudTooltip>
			</div>
		</CardHeaderActions>
	</MudCardHeader>
	<MudCardContent Class="flex-grow-1">
		<div class="d-flex align-center mb-1">
			<MudIcon Icon="@Icons.Material.Outlined.LocationOn" Size="Size.Small" Color="Color.Secondary" Class="mr-2" />
			<MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-truncate">@person.Address</MudText>
		</div>
		<div class="d-flex align-center">
			<MudIcon Icon="@Icons.Material.Outlined.Email" Size="Size.Small" Color="Color.Secondary" Class="mr-2" />
			<MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-truncate">@person.Email</MudText>
		</div>
	</MudCardContent>
</MudCard>
@code {
	[Parameter]
	public Person person { get; set; }

	[Parameter]
	public Action OnPersonDeleted{ get; set; } // Update the type to

	DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true };

	private void OpenPersonCard(DialogOptions options)
	{
		var parameter = new DialogParameters { ["person"] = person };
		DialogService.Show<PersonCard>("", parameter, options);
	}
	async Task DeletePeron(Person p, string fname, string lname)
	{
		var parameters = new DialogParameters();
		parameters.Add("ContentText", $"Do you really want to remove {fname} {lname}?");
		parameters.Add("ButtonText", "Remove");
		parameters.Add("Color", Color.Error);

		var options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

		var dialog = await DialogService.Show<ConfirmDialog>("Delete", parameters, options).Result;

		if (!dialog.Cancelled)
		{
			var status = await deletePersonUseCase.ExecuteAsync(p);
			OnPersonDeleted?.Invoke();
			Snackbar.Add(status.Reason, status.severity);
		}

	}
}
